# Assign apps to workspaces — fires when the window appears, not when launched,
# so there's no race condition between simultaneous exec calls.
# Use `xprop WM_CLASS` to confirm class names if an app lands on the wrong workspace.
assign [instance="htop-monitor"]  $ws1
assign [instance="nvtop-monitor"] $ws1
assign [class="Nvidia-settings"]  $ws1
assign [class="discord"]          $ws3
assign [class="TelegramDesktop"]  $ws3

# Launch apps on startup. assign rules above place each window correctly
# regardless of which workspace is active when the window opens.
# alacritty --class format in 0.13+: <general>,<instance> — general is the WM_CLASS
# class (used for most matching), instance is the second field targeted by assign.
exec --no-startup-id alacritty --class Alacritty,htop-monitor -e htop
exec --no-startup-id alacritty --class Alacritty,nvtop-monitor -e nvtop 
exec --no-startup-id nvidia-settings

# Firefox has no assign rule — workspace switch ensures it opens on ws2 at startup
# but future firefox windows open on whatever workspace you're currently on.
exec --no-startup-id i3-msg 'workspace 2; exec firefox'
exec --no-startup-id discord
exec --no-startup-id telegram-desktop
